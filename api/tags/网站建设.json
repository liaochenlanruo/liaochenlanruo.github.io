ode\">    clearTimeout(searchTimer);</span></span><br><span class=\"line\"><span class=\"code\">    searchTimer = setTimeout(render, 300);</span></span><br><span class=\"line\"><span class=\"code\">  &#125;);</span></span><br><span class=\"line\"><span class=\"code\"></span></span><br><span class=\"line\">  function render()&#123;</span><br><span class=\"line\"><span class=\"code\">    let kw = $(&#x27;#searchInput&#x27;).val().toLowerCase();</span></span><br><span class=\"line\"><span class=\"code\">    let list = allData.filter(it =&gt; </span></span><br><span class=\"line\"><span class=\"code\">      it.group.toLowerCase().includes(kw) || it.src.toLowerCase().includes(kw)</span></span><br><span class=\"line\"><span class=\"code\">    );</span></span><br><span class=\"line\"><span class=\"code\">    $(&#x27;#galleryResult&#x27;).html(mode === &#x27;group&#x27; ? renderGroup(list) : renderTime(list));</span></span><br><span class=\"line\"><span class=\"code\">    // 无需额外 fancybox 绑定</span></span><br><span class=\"line\"><span class=\"code\">  &#125;</span></span><br><span class=\"line\"><span class=\"code\"></span></span><br><span class=\"line\">  function renderGroup(list)&#123;</span><br><span class=\"line\"><span class=\"code\">    let groups = &#123;&#125;;</span></span><br><span class=\"line\"><span class=\"code\">    list.forEach(it =&gt; &#123;</span></span><br><span class=\"line\"><span class=\"code\">      let g = it.group;</span></span><br><span class=\"line\"><span class=\"code\">      if(!groups[g]) groups[g] = [];</span></span><br><span class=\"line\"><span class=\"code\">      groups[g].push(&#x27;/photos/&#x27; + it.src);</span></span><br><span class=\"line\"><span class=\"code\">    &#125;);</span></span><br><span class=\"line\"><span class=\"code\">    let h = &#x27;&#x27;;</span></span><br><span class=\"line\"><span class=\"code\">    for(let g in groups)&#123;</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;div class=&quot;album-group&quot;&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;div class=&quot;album-title&quot;&gt;$&#123;g&#125;&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;div class=&quot;waterfall&quot;&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      groups[g].forEach(src =&gt; &#123;</span></span><br><span class=\"line\"><span class=\"code\">        h += `&lt;div class=&quot;waterfall-item&quot;&gt;&lt;img src=&quot;$&#123;src&#125;&quot; data-fancybox-src=&quot;$&#123;src&#125;&quot; class=&quot;no-lazy gallery-img&quot; loading=&quot;lazy&quot; alt=&quot;&quot;&gt;&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      &#125;);</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;/div&gt;&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">    &#125;</span></span><br><span class=\"line\"><span class=\"code\">    return h;</span></span><br><span class=\"line\"><span class=\"code\">  &#125;</span></span><br><span class=\"line\"><span class=\"code\"></span></span><br><span class=\"line\">  function renderTime(list)&#123;</span><br><span class=\"line\"><span class=\"code\">    let dayMap = &#123;&#125;;</span></span><br><span class=\"line\"><span class=\"code\">    list.forEach(it =&gt; &#123;</span></span><br><span class=\"line\"><span class=\"code\">      let d = it.time || &#x27;未知时间&#x27;;</span></span><br><span class=\"line\"><span class=\"code\">      if(!dayMap[d]) dayMap[d] = [];</span></span><br><span class=\"line\"><span class=\"code\">      dayMap[d].push(it);</span></span><br><span class=\"line\"><span class=\"code\">    &#125;);</span></span><br><span class=\"line\"><span class=\"code\">    let days = Object.keys(dayMap).sort().reverse();</span></span><br><span class=\"line\"><span class=\"code\">    let h = &#x27;&lt;div class=&quot;timeline-box&quot;&gt;&#x27;, lastYear = &#x27;&#x27;;</span></span><br><span class=\"line\"><span class=\"code\">    days.forEach(day =&gt; &#123;</span></span><br><span class=\"line\"><span class=\"code\">      let items = dayMap[day].sort((a,b) =&gt; (a.fullTime||&#x27;&#x27;) &gt; (b.fullTime||&#x27;&#x27;) ? 1 : -1);</span></span><br><span class=\"line\"><span class=\"code\">      let y = day.substring(0,4);</span></span><br><span class=\"line\"><span class=\"code\">      if(y !== lastYear)&#123;</span></span><br><span class=\"line\"><span class=\"code\">        h += `&lt;div class=&quot;timeline-year&quot;&gt;📅 $&#123;y&#125; 年&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">        lastYear = y;</span></span><br><span class=\"line\"><span class=\"code\">      &#125;</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;div class=&quot;timeline-day&quot;&gt;$&#123;day&#125;&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;div class=&quot;waterfall&quot;&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      items.forEach(it =&gt; &#123;</span></span><br><span class=\"line\"><span class=\"code\">        let src = &#x27;/photos/&#x27; + it.src;</span></span><br><span class=\"line\"><span class=\"code\">        h += `&lt;div class=&quot;waterfall-item&quot;&gt;&lt;img src=&quot;$&#123;src&#125;&quot; data-fancybox-src=&quot;$&#123;src&#125;&quot; class=&quot;no-lazy gallery-img&quot; loading=&quot;lazy&quot; alt=&quot;&quot;&gt;&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">      &#125;);</span></span><br><span class=\"line\"><span class=\"code\">      h += `&lt;/div&gt;`;</span></span><br><span class=\"line\"><span class=\"code\">    &#125;);</span></span><br><span class=\"line\"><span class=\"code\">    return h + &#x27;&lt;/div&gt;&#x27;;</span></span><br><span class=\"line\"><span class=\"code\">  &#125;</span></span><br><span class=\"line\"><span class=\"code\"></span></span><br><span class=\"line\">  // 自定义 fancybox 打开逻辑（解决冲突的关键）</span><br><span class=\"line\">  $(document).on(&#x27;click&#x27;, &#x27;.gallery-img&#x27;, function(e) &#123;</span><br><span class=\"line\"><span class=\"code\">    let currentImages = [];</span></span><br><span class=\"line\"><span class=\"code\">    $(&#x27;.waterfall:not(.hidden) .gallery-img&#x27;).each(function() &#123;</span></span><br><span class=\"line\"><span class=\"code\">      let src = $(this).data(&#x27;fancybox-src&#x27;);</span></span><br><span class=\"line\"><span class=\"code\">      if(src) currentImages.push(&#123; src: src &#125;);</span></span><br><span class=\"line\"><span class=\"code\">    &#125;);</span></span><br><span class=\"line\"><span class=\"code\">    let clickedSrc = $(this).data(&#x27;fancybox-src&#x27;);</span></span><br><span class=\"line\"><span class=\"code\">    let index = currentImages.findIndex(img =&gt; img.src === clickedSrc);</span></span><br><span class=\"line\"><span class=\"code\">    if(index !== -1) &#123;</span></span><br><span class=\"line\"><span class=\"code\">      $.fancybox.open(currentImages, &#123; loop: true &#125;, index);</span></span><br><span class=\"line\"><span class=\"code\">    &#125;</span></span><br><span class=\"line\"><span class=\"code\">    e.preventDefault();</span></span><br><span class=\"line\"><span class=\"code\">  &#125;);</span></span><br><span class=\"line\"><span class=\"code\"></span></span><br><span class=\"line\">  // 折叠/展开事件（保持不变）</span><br><span class=\"line\">  $(document).on(&#x27;click&#x27;,&#x27;.album-title,.timeline-day&#x27;,function()&#123;</span><br><span class=\"line\"><span class=\"code\">    $(this).toggleClass(&#x27;collapsed&#x27;);</span></span><br><span class=\"line\"><span class=\"code\">    $(this).next(&#x27;.waterfall&#x27;).toggleClass(&#x27;hidden&#x27;);</span></span><br><span class=\"line\"><span class=\"code\">  &#125;);</span></span><br><span class=\"line\"><span class=\"code\">&#125;);</span></span><br><span class=\"line\"><span class=\"code\">&lt;/script&gt;</span></span><br></pre></td></tr></table></figure>\n\n<hr>\n<h1 id=\"五、菜单配置（themes-bamboo-config-yml）\"><a href=\"#五、菜单配置（themes-bamboo-config-yml）\" class=\"headerlink\" title=\"五、菜单配置（themes&#x2F;bamboo&#x2F;_config.yml）\"></a>五、菜单配置（themes&#x2F;bamboo&#x2F;_config.yml）</h1><figure class=\"highlight yaml\"><table><tr><td class=\"gutter\"><pre><span class=\"line\">1</span><br><span class=\"line\">2</span><br><span class=\"line\">3</span><br><span class=\"line\">4</span><br><span class=\"line\">5</span><br><span class=\"line\">6</span><br><span class=\"line\">7</span><br><span class=\"line\">8</span><br><span class=\"line\">9</span><br><span class=\"line\">10</span><br><span class=\"line\">11</span><br><span class=\"line\">12</span><br><span class=\"line\">13</span><br><span class=\"line\">14</span><br><span class=\"line\">15</span><br><span class=\"line\">16</span><br></pre></td><td class=\"code\"><pre><span class=\"line\"><span class=\"attr\">menu:</span></span><br><span class=\"line\">  <span class=\"attr\">Home:</span></span><br><span class=\"line\">    <span class=\"attr\">url:</span> <span class=\"string\">/</span></span><br><span class=\"line\">    <span class=\"attr\">icon:</span> <span class=\"string\">fas</span> <span class=\"string\">fa-home</span></span><br><span class=\"line\">  <span class=\"attr\">Archives:</span></span><br><span class=\"line\">    <span class=\"attr\">url:</span> <span class=\"string\">/archives</span></span><br><span class=\"line\">    <span class=\"attr\">icon:</span> <span class=\"string\">fas</span> <span class=\"string\">fa-archive</span></span><br><span class=\"line\">  <span class=\"attr\">Tags:</span></span><br><span class=\"line\">    <span class=\"attr\">url:</span> <span class=\"string\">/tags</span></span><br><span class=\"line\">    <span class=\"attr\">icon:</span> <span class=\"string\">fas</span> <span class=\"string\">fa-tags</span></span><br><span class=\"line\">